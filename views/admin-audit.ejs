<%- include('partials/header', { title, page }) %>

<div class="admin-container">
  <header class="admin-header">
    <div>
      <p class="admin-kicker">QuickShare</p>
      <h1 class="admin-title">审计日志</h1>
      <p class="admin-subtitle">已记录 <%= pagination.total %> 条操作事件</p>
    </div>
    <%- include('partials/admin-nav', { current: 'audit' }) %>
  </header>

  <section class="card admin-card">
    <% if (logs.length === 0) { %>
      <div class="admin-empty">
        <p>暂无审计事件。</p>
      </div>
    <% } else { %>
      <div class="admin-table-wrap" tabindex="0" aria-label="审计日志，可横向滚动">
        <table class="admin-table admin-audit-table">
          <caption class="sr-only">审计日志</caption>
          <thead>
            <tr>
              <th scope="col">时间</th>
              <th scope="col">操作</th>
              <th scope="col">分享 ID</th>
              <th scope="col">详情</th>
              <th scope="col">IP 地址</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach((log) => { %>
              <tr>
                <td><time datetime="<%= new Date(log.createdAt).toISOString() %>"><%= new Date(log.createdAt).toLocaleString('zh-CN', { hour12: false }) %></time></td>
                <td><span class="admin-audit-badge <%= log.action %>"><%= log.action %></span></td>
                <td>
                  <% if (log.pageId) { %>
                    <a href="/admin/pages/<%= encodeURIComponent(log.pageId) %>"><%= log.pageId %></a>
                  <% } else { %>
                    <span class="admin-muted">—</span>
                  <% } %>
                </td>
                <td>
                  <% if (log.details) { %>
                    <code class="admin-password-value admin-audit-details"><%= log.details %></code>
                  <% } else { %>
                    <span class="admin-muted">—</span>
                  <% } %>
                </td>
                <td><span class="admin-muted"><%= log.ip || '—' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <nav class="admin-pagination" aria-label="审计日志分页">
        <% if (pagination.hasPrevious) { %>
          <a class="cyber-btn cyber-btn-secondary" href="/admin/audit?page=<%= pagination.page - 1 %>">上一页</a>
        <% } else { %>
          <span class="cyber-btn cyber-btn-secondary disabled" aria-disabled="true">上一页</span>
        <% } %>
        <span class="admin-page-count">第 <%= pagination.page %> / <%= pagination.totalPages %> 页</span>
        <% if (pagination.hasNext) { %>
          <a class="cyber-btn cyber-btn-secondary" href="/admin/audit?page=<%= pagination.page + 1 %>">下一页</a>
        <% } else { %>
          <span class="cyber-btn cyber-btn-secondary disabled" aria-disabled="true">下一页</span>
        <% } %>
      </nav>
    <% } %>
  </section>
</div>

<%- include('partials/footer', { page }) %>
