<%- include('partials/header', { title, page }) %>

<div class="admin-container">
  <header class="admin-header">
    <div>
      <p class="admin-kicker">QuickShare</p>
      <h1 class="admin-title">Audit Log</h1>
      <p class="admin-subtitle"><%= pagination.total %> events recorded</p>
    </div>
    <div class="admin-actions">
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/stats">
        <i class="fas fa-chart-bar" aria-hidden="true"></i>
        <span>Stats</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/apis">
        <i class="fas fa-key" aria-hidden="true"></i>
        <span>API</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/pages">
        <i class="fas fa-table" aria-hidden="true"></i>
        <span>Pages</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/">
        <i class="fas fa-plus" aria-hidden="true"></i>
        <span>Create</span>
      </a>
    </div>
  </header>

  <section class="card admin-card">
    <% if (logs.length === 0) { %>
      <div class="admin-empty" style="padding: 2rem;">
        <p>No audit events yet.</p>
      </div>
    <% } else { %>
      <div class="admin-table-wrap">
        <table class="admin-table admin-audit-table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Action</th>
              <th>Page ID</th>
              <th>Details</th>
              <th>IP</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach((log) => { %>
              <tr>
                <td><time datetime="<%= new Date(log.createdAt).toISOString() %>"><%= new Date(log.createdAt).toLocaleString('zh-CN', { hour12: false }) %></time></td>
                <td><span class="admin-audit-badge <%= log.action %>"><%= log.action %></span></td>
                <td>
                  <% if (log.pageId) { %>
                    <a href="/admin/pages/<%= encodeURIComponent(log.pageId) %>"><%= log.pageId %></a>
                  <% } else { %>
                    <span class="admin-muted">—</span>
                  <% } %>
                </td>
                <td>
                  <% if (log.details) { %>
                    <code class="admin-password-value" style="font-size: 0.75rem;"><%= log.details %></code>
                  <% } else { %>
                    <span class="admin-muted">—</span>
                  <% } %>
                </td>
                <td><span class="admin-muted"><%= log.ip || '—' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <nav class="admin-pagination" aria-label="Audit log pagination">
        <% if (pagination.hasPrevious) { %>
          <a class="cyber-btn cyber-btn-secondary" href="/admin/audit?page=<%= pagination.page - 1 %>">Previous</a>
        <% } else { %>
          <span class="cyber-btn cyber-btn-secondary disabled">Previous</span>
        <% } %>
        <span class="admin-page-count">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
        <% if (pagination.hasNext) { %>
          <a class="cyber-btn cyber-btn-secondary" href="/admin/audit?page=<%= pagination.page + 1 %>">Next</a>
        <% } else { %>
          <span class="cyber-btn cyber-btn-secondary disabled">Next</span>
        <% } %>
      </nav>
    <% } %>
  </section>
</div>

<%- include('partials/footer', { page }) %>
