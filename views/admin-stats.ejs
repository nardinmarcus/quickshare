<%- include('partials/header', { title, page }) %>

<div class="admin-container">
  <header class="admin-header">
    <div>
      <p class="admin-kicker">QuickShare</p>
      <h1 class="admin-title">数据统计</h1>
      <p class="admin-subtitle">基于当前分享记录的创建与访问数据</p>
    </div>
    <%- include('partials/admin-nav', { current: 'stats' }) %>
  </header>

  <section class="card admin-access-card" aria-labelledby="homepage-access-title">
    <div class="admin-access-copy">
      <p class="admin-access-kicker">Access policy</p>
      <h2 id="homepage-access-title">首页访问控制</h2>
      <p id="homepage-access-description">公开模式允许任何访客进入首页并创建分享；管理后台仍受独立密码保护。</p>
    </div>
    <div class="admin-access-control">
      <span
        id="homepage-access-state"
        class="admin-access-state"
        data-state="<%= homepagePasswordRequired ? 'locked' : 'public' %>"
      >
        <i class="fas <%= homepagePasswordRequired ? 'fa-lock' : 'fa-globe' %>" aria-hidden="true"></i>
        <span><%= homepagePasswordRequired ? '需要密码' : '公开发布' %></span>
      </span>
      <label class="admin-toggle-label" for="homepage-access-toggle">
        <input
          type="checkbox"
          id="homepage-access-toggle"
          role="switch"
          aria-describedby="homepage-access-description homepage-access-status"
          <%= homepagePasswordRequired ? 'checked' : '' %>
        >
        <span class="admin-toggle-slider" aria-hidden="true"></span>
        <span class="admin-toggle-text">进入首页需要密码</span>
      </label>
      <p id="homepage-access-status" class="admin-access-status" role="status" aria-live="polite" aria-atomic="true">
        当前：<%= homepagePasswordRequired ? '需要密码' : '公开发布' %>
      </p>
    </div>
  </section>

  <section class="admin-metric-grid" aria-label="汇总指标">
    <article class="card admin-metric-card">
      <span>分享总数</span>
      <strong><%= stats.total %></strong>
    </article>
    <article class="card admin-metric-card">
      <span>公开分享</span>
      <strong><%= stats.public %></strong>
      <small>占总数 <%= stats.publicPercent %>%</small>
    </article>
    <article class="card admin-metric-card">
      <span>密码保护</span>
      <strong><%= stats.protected %></strong>
      <small>占总数 <%= stats.protectedPercent %>%</small>
    </article>
    <article class="card admin-metric-card">
      <span>最近创建</span>
      <strong class="admin-metric-date">
        <% if (stats.latestCreatedAt) { %>
          <%= formatManagementDateTime(stats.latestCreatedAt) %>
        <% } else { %>
          暂无
        <% } %>
      </strong>
    </article>
  </section>

  <section class="admin-dashboard-grid">
    <article class="card admin-chart-card" aria-labelledby="content-types-title" aria-describedby="content-types-summary">
      <div class="admin-content-header">
        <h2 id="content-types-title">内容类型</h2>
      </div>
      <% if (stats.byType.length === 0) { %>
        <p id="content-types-summary" class="admin-muted">暂无分享。</p>
      <% } else { %>
        <p id="content-types-summary" class="admin-chart-summary">
          <%= stats.byType.map((item) => item.codeType + ' ' + item.count + ' 个').join('，') %>。
        </p>
        <div class="admin-bar-list" aria-hidden="true">
          <% stats.byType.forEach((item) => { %>
            <div class="admin-bar-row">
              <div class="admin-bar-label">
                <span><%= item.codeType %></span>
                <strong><%= item.count %></strong>
              </div>
              <div class="admin-bar-track">
                <div class="admin-bar-fill" style="width: <%= item.percent %>%;"></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </article>

    <article class="card admin-chart-card" aria-labelledby="protection-title" aria-describedby="protection-summary">
      <div class="admin-content-header">
        <h2 id="protection-title">保护方式</h2>
      </div>
      <p id="protection-summary" class="admin-chart-summary">
        公开分享 <%= stats.public %> 个，密码保护 <%= stats.protected %> 个。
      </p>
      <div aria-hidden="true">
        <div class="admin-stacked-bar">
          <div class="admin-stack-public" style="width: <%= stats.publicPercent %>%;"></div>
          <div class="admin-stack-protected" style="width: <%= stats.protectedPercent %>%;"></div>
        </div>
        <div class="admin-legend">
          <span><i class="admin-legend-public"></i>公开 <%= stats.public %></span>
          <span><i class="admin-legend-protected"></i>密码保护 <%= stats.protected %></span>
        </div>
      </div>
    </article>
  </section>

  <section class="card admin-chart-card" aria-labelledby="top-viewed-title" aria-describedby="top-viewed-summary">
    <div class="admin-content-header">
      <h2 id="top-viewed-title">访问最多</h2>
    </div>
    <% if (!stats.topViewed || stats.topViewed.length === 0) { %>
      <p id="top-viewed-summary" class="admin-muted">暂无访问记录。</p>
    <% } else { %>
      <p id="top-viewed-summary" class="admin-chart-summary">
        <%= stats.topViewed.map((item) => item.title + ' ' + item.viewCount + ' 次').join('，') %>。
      </p>
      <div class="admin-top-viewed-list">
        <% stats.topViewed.forEach((item) => { %>
          <div class="admin-top-viewed-row">
            <a class="admin-top-viewed-title" href="/admin/pages/<%= encodeURIComponent(item.id) %>"><%= item.title %></a>
            <div class="admin-top-viewed-bar-track" aria-hidden="true">
              <div class="admin-top-viewed-bar-fill" style="width: <%= stats.topViewed[0].viewCount > 0 ? (item.viewCount / stats.topViewed[0].viewCount * 100) : 0 %>%; opacity: <%= stats.topViewed[0].viewCount > 0 ? 0.4 + (item.viewCount / stats.topViewed[0].viewCount) * 0.6 : 0.4 %>;"></div>
            </div>
            <span class="admin-top-viewed-count"><%= item.viewCount %> 次</span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <%
    const recentTotal = stats.recentDays.reduce((sum, day) => sum + Number(day.count || 0), 0);
  %>
  <section class="card admin-chart-card" aria-labelledby="recent-shares-title" aria-describedby="recent-shares-summary">
    <div class="admin-content-header">
      <h2 id="recent-shares-title">最近 14 天创建趋势</h2>
    </div>
    <p id="recent-shares-summary" class="admin-chart-summary">最近 14 天共创建 <%= recentTotal %> 个分享。</p>
    <div class="admin-timeline" aria-hidden="true">
      <% stats.recentDays.forEach((day) => { %>
        <div class="admin-day-column">
          <div class="admin-day-count"><%= day.count %></div>
          <div class="admin-day-track">
            <div class="admin-day-fill" style="height: <%= day.percent %>%;"></div>
          </div>
          <time datetime="<%= day.date %>"><%= day.label %></time>
        </div>
      <% }) %>
    </div>
  </section>
</div>

<div
  id="homepage-access-confirm"
  class="admin-modal"
  role="alertdialog"
  aria-modal="true"
  aria-labelledby="homepage-access-confirm-title"
  aria-describedby="homepage-access-confirm-description homepage-access-confirm-status"
  aria-busy="false"
  hidden
>
  <div class="admin-modal-backdrop" aria-hidden="true"></div>
  <div class="admin-modal-content" tabindex="-1">
    <h3 id="homepage-access-confirm-title">确认公开首页</h3>
    <p id="homepage-access-confirm-description">关闭密码后，任何访客都可以进入首页并创建分享。管理后台仍会继续要求独立密码。</p>
    <p class="admin-modal-warning">公开模式会立即对新的匿名请求生效。</p>
    <p id="homepage-access-confirm-status" class="admin-modal-status" role="status" aria-live="polite" aria-atomic="true" tabindex="-1"></p>
    <div class="admin-modal-actions">
      <button type="button" class="cyber-btn cyber-btn-secondary" id="homepage-access-cancel">取消</button>
      <button type="button" class="cyber-btn" id="homepage-access-confirm-button">确认公开</button>
    </div>
  </div>
</div>

<script src="/js/admin-settings.js"></script>
<%- include('partials/footer', { page }) %>
