<%- include('partials/header', { title, page, csrfToken }) %>

<div class="main-container">
  <header class="app-header">
    <h1 class="app-title">QuickShare<span class="brand-pulse"></span></h1>
    <p class="app-description">粘贴代码，一键分享</p>
  </header>

  <div class="content-area">
    <div class="card input-card">
      <div class="input-section">
        <div id="loading-indicator" class="loading-indicator">
          <div class="spinner"></div>
          <span>处理中...</span>
        </div>

        <div id="code-input-container" role="tabpanel">
          <div class="content-input-toolbar">
            <label for="html-input" class="content-label">分享内容</label>
            <div class="content-input-actions">
              <div id="code-type-indicator" class="code-type-indicator html-type">
                <i class="fas fa-code" aria-hidden="true"></i>
                <span id="code-type-text">HTML</span>
              </div>
              <label id="upload-file-trigger" for="html-file" class="upload-file-trigger micro-interaction" aria-label="上传文件">
                <i class="fas fa-file-upload" aria-hidden="true"></i>
                <span>上传文件</span>
                <span class="upload-file-badge" aria-hidden="true">常用</span>
              </label>
            </div>
          </div>
          <textarea id="html-input" class="cyber-input" placeholder="在这里粘贴你的 HTML / Markdown / SVG / Mermaid 代码..."></textarea>
        </div>

        <div class="hidden">
          <input id="html-file" type="file" class="hidden" accept=".html,.htm,.md,.markdown,.svg,.mmd,.mermaid" aria-label="上传文件" />
          <p id="file-name" class="file-name-text"></p>
        </div>

        <div id="markdown-theme-selector" class="markdown-theme-selector hidden">
          <div class="theme-selector-header">
            <i class="fas fa-palette" aria-hidden="true"></i>
            <span class="theme-label">Markdown Theme</span>
          </div>
          <select id="markdown-theme" class="theme-select">
            <option value="bytedance" selected>ByteDance 蓝绿</option>
            <option value="github">GitHub 经典</option>
            <option value="apple">Apple 极简</option>
            <option value="notion">Notion 笔记</option>
            <option value="claude">Claude 暖调</option>
          </select>
        </div>

        <section id="publish-settings" class="publish-settings" aria-labelledby="publish-settings-title">
          <h2 id="publish-settings-title" class="publish-settings-title">发布设置</h2>

          <div class="publish-settings-grid">
            <div class="publish-field">
              <label for="share-title">标题（可选）</label>
              <input type="text" id="share-title" maxlength="160" placeholder="留空时自动提取标题">
            </div>
            <div class="publish-field">
              <label for="share-description">描述（可选）</label>
              <textarea id="share-description" rows="2" maxlength="500" placeholder="用于分享摘要"></textarea>
            </div>
            <div class="publish-field">
              <label for="share-expires">到期时间（可选）</label>
              <input type="datetime-local" id="share-expires">
              <span id="share-expires-hint" class="field-hint"></span>
            </div>
          </div>

          <fieldset class="access-policy">
            <legend>访问方式</legend>
            <div class="access-mode-options">
              <label class="access-mode-option" for="access-link">
                <input type="radio" id="access-link" name="access-mode" value="link" checked>
                <span>
                  <strong>持有链接可访问</strong>
                  <small>任何拿到链接的人都可以查看</small>
                </span>
              </label>
              <label class="access-mode-option" for="password-toggle">
                <input type="radio" id="password-toggle" name="access-mode" value="password">
                <span>
                  <strong>密码保护</strong>
                  <small>查看前需要输入访问密码</small>
                </span>
              </label>
            </div>

            <div id="password-settings" class="password-settings hidden">
              <div id="password-default-mode" class="password-default-mode">
                <span id="password-mode-summary" aria-live="polite">自动生成 6 位数字密码</span>
                <button type="button" id="use-custom-password-btn" class="mode-switch-btn">改用自定义密码</button>
              </div>

              <div id="password-custom-mode" class="password-custom-mode hidden">
                <label for="custom-password-input">自定义密码</label>
                <div class="custom-password-row">
                  <input
                    type="password"
                    id="custom-password-input"
                    class="custom-password-input"
                    placeholder="4–12 位"
                    minlength="4"
                    maxlength="12"
                    autocomplete="new-password"
                    aria-describedby="custom-password-hint"
                    aria-invalid="false"
                  >
                  <button type="button" id="toggle-custom-password" class="toggle-password-btn" aria-label="显示密码">
                    <i class="fas fa-eye" aria-hidden="true"></i>
                  </button>
                  <button type="button" id="confirm-custom-password" class="confirm-btn">使用此密码</button>
                  <button type="button" id="cancel-custom-password" class="mode-switch-btn">使用自动密码</button>
                </div>
                <span id="custom-password-hint" class="field-hint" aria-live="polite">仅限英文字母、数字及 !@#$%^&amp;*()_+-=.,?~</span>
              </div>
            </div>
          </fieldset>
        </section>

        <div class="button-row">
          <div class="button-group">
            <button id="clear-button" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="清空内容" aria-label="清空内容">
              <i class="fas fa-eraser mr-1" aria-hidden="true"></i>清除
            </button>
            <button id="prepublish-preview-button" class="cyber-btn cyber-btn-secondary micro-interaction" type="button" aria-busy="false">
              <i class="fas fa-eye mr-1" aria-hidden="true"></i>安全预览
            </button>
            <button id="generate-button" class="cyber-btn cyber-btn-primary tooltip micro-interaction" data-tooltip="发布并生成链接" aria-label="发布并生成链接" aria-busy="false">
              <i class="fas fa-link mr-1" aria-hidden="true"></i>发布并生成链接
            </button>
          </div>
        </div>

        <p id="publish-status" class="publish-status" role="status" aria-live="polite" aria-atomic="true" data-state="idle">准备发布</p>
        <p id="publish-error" class="publish-error hidden" role="alert" tabindex="-1"></p>
      </div>
    </div>

    <section id="publish-preview" class="card publish-preview" aria-labelledby="publish-preview-title" hidden>
      <div class="publish-preview-header">
        <div>
          <p class="result-eyebrow">发布前检查</p>
          <h2 id="publish-preview-title" class="section-title" tabindex="-1">安全预览</h2>
        </div>
        <button id="close-publish-preview" type="button" class="action-btn action-btn-neutral" aria-label="关闭预览">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <iframe
        id="publish-preview-frame"
        class="publish-preview-frame"
        title="待发布内容预览"
        sandbox="allow-scripts"
        referrerpolicy="no-referrer"
      ></iframe>
    </section>

    <section id="result-section" class="card result-card hidden" aria-labelledby="result-title">
      <div class="result-heading">
        <div>
          <p id="result-eyebrow" class="result-eyebrow">发布回执</p>
          <h2 id="result-title" class="section-title" tabindex="-1">已发布</h2>
          <p id="result-page-title" class="result-page-title"></p>
        </div>
        <span class="result-success-mark" aria-hidden="true"><i class="fas fa-check"></i></span>
      </div>

      <div class="result-container">
        <a id="result-url" class="result-url" href="#" target="_blank" rel="noopener noreferrer"></a>
      </div>

      <dl class="result-summary" aria-label="分享设置摘要">
        <div>
          <dt>内容类型</dt>
          <dd id="result-type">—</dd>
        </div>
        <div>
          <dt>访问方式</dt>
          <dd id="result-access">—</dd>
        </div>
        <div>
          <dt>有效期</dt>
          <dd id="result-expiry">—</dd>
        </div>
      </dl>

      <div id="result-password-row" class="result-password-row hidden">
        <span class="password-label">访问密码：</span>
        <code id="generated-password" class="generated-password"></code>
        <button type="button" id="copy-password-button" class="result-text-button">复制密码</button>
      </div>

      <div class="result-actions">
        <button id="open-share-button" type="button" class="cyber-btn cyber-btn-primary">
          <i class="fas fa-external-link-alt mr-1" aria-hidden="true"></i>打开分享页
        </button>
        <button id="copy-button" type="button" class="cyber-btn cyber-btn-secondary">
          <i class="fas fa-copy mr-1" aria-hidden="true"></i>复制链接
        </button>
        <button type="button" id="copy-password-link" class="cyber-btn cyber-btn-secondary hidden">
          <i class="fas fa-key mr-1" aria-hidden="true"></i>复制密码和链接
        </button>
        <button id="continue-button" type="button" class="cyber-btn cyber-btn-secondary"><i class="fas fa-plus mr-1" aria-hidden="true"></i>继续创建</button>
      </div>
      <textarea id="manual-copy-output" class="manual-copy-output" aria-label="待手动复制的内容" readonly hidden></textarea>
    </section>
  </div>

  <footer class="app-footer">
    <p class="footer-text">&copy;2026 <a href="https://x.com/nardinmarcus" target="_blank" rel="noopener noreferrer">Namoo</a></p>
  </footer>
</div>

<%- include('partials/footer', { page }) %>
