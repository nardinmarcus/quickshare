<%- include('partials/header', { title, page, csrfToken }) %>

<div class="main-container">
  <header class="app-header">
    <h1 class="app-title">QuickShare<span class="brand-pulse"></span></h1>
    <p class="app-description">粘贴代码，一键分享</p>
  </header>

  <div class="content-area">
    <div class="card input-card">
      <div class="input-section">
        <div id="loading-indicator" class="loading-indicator">
          <div class="spinner"></div>
          <span>处理中...</span>
        </div>

        <div id="code-input-container" role="tabpanel">
          <div id="code-type-indicator" class="code-type-indicator html-type">
            <i class="fas fa-code"></i>
            <span id="code-type-text">HTML</span>
          </div>
          <textarea id="html-input" class="cyber-input" placeholder="在这里粘贴你的 HTML / Markdown / SVG / Mermaid 代码..." aria-label="代码输入区域"></textarea>
        </div>

        <div class="hidden">
          <input id="html-file" type="file" class="hidden" accept=".html,.htm,.md,.markdown,.svg,.mmd,.mermaid" aria-label="上传文件" />
          <p id="file-name" class="file-name-text"></p>
        </div>

        <div id="markdown-theme-selector" class="markdown-theme-selector hidden">
          <div class="theme-selector-header">
            <i class="fas fa-palette" aria-hidden="true"></i>
            <span class="theme-label">Markdown Theme</span>
          </div>
          <select id="markdown-theme" class="theme-select">
            <option value="bytedance" selected>ByteDance 蓝绿</option>
            <option value="github">GitHub 经典</option>
            <option value="apple">Apple 极简</option>
            <option value="notion">Notion 笔记</option>
            <option value="claude">Claude 暖调</option>
          </select>
        </div>

        <section id="publish-settings" class="publish-settings" aria-labelledby="publish-settings-title">
          <h2 id="publish-settings-title" class="publish-settings-title">发布设置</h2>

          <div class="publish-settings-grid">
            <div class="publish-field">
              <label for="share-title">标题（可选）</label>
              <input type="text" id="share-title" maxlength="160" placeholder="留空时自动提取标题">
            </div>
            <div class="publish-field">
              <label for="share-description">描述（可选）</label>
              <textarea id="share-description" rows="2" maxlength="500" placeholder="用于分享摘要"></textarea>
            </div>
            <div class="publish-field">
              <label for="share-expires">到期时间（可选）</label>
              <input type="datetime-local" id="share-expires">
              <span id="share-expires-hint" class="field-hint"></span>
            </div>
          </div>

          <fieldset class="access-policy">
            <legend>访问方式</legend>
            <div class="access-mode-options">
              <label class="access-mode-option" for="access-link">
                <input type="radio" id="access-link" name="access-mode" value="link" checked>
                <span>
                  <strong>持有链接可访问</strong>
                  <small>任何拿到链接的人都可以查看</small>
                </span>
              </label>
              <label class="access-mode-option" for="password-toggle">
                <input type="radio" id="password-toggle" name="access-mode" value="password">
                <span>
                  <strong>密码保护</strong>
                  <small>查看前需要输入访问密码</small>
                </span>
              </label>
            </div>

            <div id="password-settings" class="password-settings hidden">
              <div id="password-default-mode" class="password-default-mode">
                <span id="password-mode-summary">自动生成 6 位数字密码</span>
                <button type="button" id="use-custom-password-btn" class="mode-switch-btn">改用自定义密码</button>
              </div>

              <div id="password-custom-mode" class="password-custom-mode hidden">
                <label for="custom-password-input">自定义密码</label>
                <div class="custom-password-row">
                  <input
                    type="password"
                    id="custom-password-input"
                    class="custom-password-input"
                    placeholder="4–12 位"
                    minlength="4"
                    maxlength="12"
                    autocomplete="new-password"
                    aria-describedby="custom-password-hint"
                    aria-invalid="false"
                  >
                  <button type="button" id="toggle-custom-password" class="toggle-password-btn" aria-label="显示密码">
                    <i class="fas fa-eye" aria-hidden="true"></i>
                  </button>
                  <button type="button" id="confirm-custom-password" class="confirm-btn">使用此密码</button>
                  <button type="button" id="cancel-custom-password" class="mode-switch-btn">使用自动密码</button>
                </div>
                <span id="custom-password-hint" class="field-hint">仅限英文字母、数字及 !@#$%^&amp;*()_+-=.,?~</span>
              </div>
            </div>
          </fieldset>
        </section>

        <div class="button-row">
          <div>
            <label for="html-file" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="上传文件" aria-label="上传文件">
              <i class="fas fa-file-upload mr-1" aria-hidden="true"></i>上传文件
            </label>
          </div>
          <div class="button-group">
            <button id="clear-button" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="清空内容" aria-label="清空内容">
              <i class="fas fa-eraser mr-1" aria-hidden="true"></i>清除
            </button>
            <button id="generate-button" class="cyber-btn cyber-btn-primary tooltip micro-interaction" data-tooltip="发布并生成链接" aria-label="发布并生成链接">
              <i class="fas fa-link mr-1" aria-hidden="true"></i>发布并生成链接
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="result-section" class="card result-card hidden" aria-live="polite">
      <h3 class="section-title">链接已生成</h3>
      <div class="result-container">
        <div id="result-url" class="result-url" tabindex="0"></div>
        <div class="action-buttons">
          <button id="preview-button" class="action-btn preview-btn tooltip micro-interaction" data-tooltip="在新窗口预览" aria-label="在新窗口预览">
            <i class="fas fa-external-link-alt" aria-hidden="true"></i>
          </button>
          <button id="copy-button" class="action-btn tooltip micro-interaction" data-tooltip="复制链接" aria-label="复制链接">
            <i class="fas fa-copy" aria-hidden="true"></i>
          </button>
        </div>
      </div>

      <div id="result-password-row" class="result-password-row hidden">
        <span class="password-label">访问密码：</span>
        <code id="generated-password" class="generated-password" title="点击复制密码"></code>
        <button type="button" id="copy-password-link" class="copy-password-link">复制密码和网址</button>
      </div>

    </div>
  </div>

  <footer class="app-footer">
    <p class="footer-text">&copy;2026 <a href="https://x.com/nardinmarcus" target="_blank" rel="noopener noreferrer">Namoo</a></p>
  </footer>
</div>

<%- include('partials/footer', { page }) %>
