<%- include('partials/header', { title, page, csrfToken }) %>

<div class="main-container">
  <header class="app-header">
    <h1 class="app-title">QuickShare</h1>
    <p class="app-description">粘贴代码，一键分享</p>
  </header>

  <div class="content-area">
    <div class="card input-card">
      <div class="input-section">
        <div id="loading-indicator" class="loading-indicator">
          <div class="spinner"></div>
          <span>处理中...</span>
        </div>

        <div id="code-input-container" role="tabpanel">
          <div id="code-type-indicator" class="code-type-indicator html-type">
            <i class="fas fa-code"></i>
            <span id="code-type-text">HTML</span>
          </div>
          <textarea id="html-input" class="cyber-input" placeholder="在这里粘贴你的 HTML / Markdown / SVG / Mermaid 代码..." aria-label="代码输入区域"></textarea>
        </div>

        <div class="hidden">
          <input id="html-file" type="file" class="hidden" accept=".html,.htm" aria-label="上传 HTML 文件" />
          <p id="file-name" class="file-name-text"></p>
        </div>

        <div class="button-row">
          <div>
            <label for="html-file" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="上传HTML文件" aria-label="上传HTML文件">
              <i class="fas fa-file-upload mr-1" aria-hidden="true"></i>上传文件
            </label>
          </div>
          <div class="button-group">
            <button id="clear-button" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="清空内容" aria-label="清空内容">
              <i class="fas fa-eraser mr-1" aria-hidden="true"></i>清除
            </button>
            <button id="generate-button" class="cyber-btn cyber-btn-primary tooltip micro-interaction" data-tooltip="生成分享链接" aria-label="生成分享链接">
              <i class="fas fa-link mr-1" aria-hidden="true"></i>生成链接
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="result-section" class="card result-card hidden" aria-live="polite">
      <h3 class="section-title">链接已生成</h3>
      <div class="result-container">
        <div id="result-url" class="result-url" tabindex="0"></div>
        <div class="action-buttons">
          <button id="preview-button" class="action-btn preview-btn tooltip micro-interaction" data-tooltip="在新窗口预览" aria-label="在新窗口预览">
            <i class="fas fa-external-link-alt" aria-hidden="true"></i>
          </button>
          <button id="copy-button" class="action-btn tooltip micro-interaction" data-tooltip="复制链接" aria-label="复制链接">
            <i class="fas fa-copy" aria-hidden="true"></i>
          </button>
        </div>
      </div>

      <div class="password-protection-toggle">
        <div class="protection-controls">
          <div class="switch-container">
            <input type="checkbox" id="password-toggle" class="switch-checkbox">
            <label for="password-toggle" class="switch-label"></label>
          </div>

          <!-- 默认模式：显示密码 + 自定义密码按钮 -->
          <div id="password-default-mode" class="password-default-mode hidden">
            <span class="password-label">密码：</span>
            <span id="generated-password" class="generated-password" title="点击复制密码"></span>
            <button type="button" id="use-custom-password-btn" class="mode-switch-btn">自定义密码</button>
          </div>

          <!-- 自定义模式：输入框 + 确认 + 取消 -->
          <div id="password-custom-mode" class="password-custom-mode hidden">
            <input
              type="password"
              id="custom-password-input"
              class="custom-password-input"
              placeholder="4-12位"
              minlength="4"
              maxlength="12"
              autocomplete="new-password"
            >
            <button type="button" id="toggle-custom-password" class="toggle-password-btn" aria-label="Toggle password visibility">
              <i class="fas fa-eye" aria-hidden="true"></i>
            </button>
            <button type="button" id="confirm-custom-password" class="confirm-btn">确认</button>
            <button type="button" id="cancel-custom-password" class="mode-switch-btn">默认密码</button>
          </div>

          <a href="#" id="copy-password-link" class="copy-password-link hidden">复制密码和网址</a>
        </div>
      </div>
    </div>
  </div>

  <footer class="app-footer">
    <p class="footer-text">&copy;2026 <a href="https://x.com/nardinmarcus" target="_blank" rel="noopener noreferrer">Namoo</a></p>
  </footer>
</div>

<%- include('partials/footer', { page }) %>
