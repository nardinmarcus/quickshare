<%- include('partials/header', { title, page }) %>

<div class="main-container">
  <header class="app-header">
    <div class="title-container">
      <h1 class="app-title">QuickShare<span class="brand-pulse"></span></h1>
    </div>
    <p class="app-description">分享AI生成内容的最佳方式</p>
  </header>

  <div class="code-input-area">
    <div class="centered-password-container">
      <div class="card password-card centered-password-card">
        <h2 class="card-title"><i class="fas fa-lock" style="margin-right: 10px; color: var(--accent);" aria-hidden="true"></i>此内容受密码保护</h2>
        <p class="password-description">输入访问密码后即可查看分享内容</p>

        <% if (error) { %>
          <div class="error-message"><%= error %></div>
        <% } %>

        <form class="password-form" id="passwordForm" data-page-id="<%= id %>" aria-busy="false">
          <label for="page-password">请输入密码</label>
          <div class="password-unlock-row">
            <input
              type="password"
              id="page-password"
              name="password"
              class="password-input"
              placeholder="访问密码"
              autocomplete="current-password"
              aria-describedby="password-error"
              aria-invalid="false"
              autofocus
              spellcheck="false">
            <button type="submit" id="password-submit" class="cyber-btn cyber-btn-primary">解锁并查看</button>
          </div>
          <p id="password-error" class="password-form-error" role="alert" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>

</div>

<script src="/js/password.js"></script>

<%- include('partials/footer', { page }) %>
