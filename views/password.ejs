<%- include('partials/header', { title, page }) %>

<div class="main-container">
  <header class="app-header">
    <div class="title-container">
      <h1 class="app-title">QuickShare</h1>
    </div>
    <p class="app-description">分享AI生成内容的最佳方式</p>
  </header>

  <div class="code-input-area">
    <div class="centered-password-container">
      <div class="card password-card centered-password-card">
        <h2 class="card-title"><i class="fas fa-lock" style="margin-right: 10px; color: var(--accent);"></i>此内容已加密</h2>
        <p class="password-description">请输入密码</p>

        <% if (error) { %>
          <div class="error-message"><%= error %></div>
        <% } %>

        <form class="password-form" id="passwordForm" autocomplete="off" data-lpignore="true" data-1p-ignore>
          <div class="password-input-container">
            <input
              type="text"
              name="pin_code"
              maxlength="<%= passwordLength %>"
              class="password-input non-password"
              placeholder="<%= '*'.repeat(passwordLength) %>"
              autocomplete="off"
              autofocus
              inputmode="numeric"
              pattern="[0-9]*"
              spellcheck="false"
              autocorrect="off"
              autocapitalize="off">
            <div class="digit-indicators">
              <% for (let i = 0; i < passwordLength; i += 1) { %>
                <span class="digit-indicator"></span>
              <% } %>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

</div>

<script>
  const pageId = <%- JSON.stringify(id) %>;
  const passwordLength = <%= passwordLength %>;

  document.addEventListener('DOMContentLoaded', function() {
    const passwordInput = document.querySelector('.password-input');

    if (!passwordInput) {
      return;
    }

    passwordInput.addEventListener('input', function(event) {
      const value = event.target.value;
      event.target.value = value;
      handlePasswordInput(value);
    });
  });

  function setIndicatorState(state) {
    document.querySelectorAll('.digit-indicator').forEach(function(indicator) {
      indicator.classList.remove('filled', 'correct', 'incorrect');
      if (state) {
        indicator.classList.add(state);
      }
    });
  }

  function handlePasswordInput(value) {
    const indicators = document.querySelectorAll('.digit-indicator');

    indicators.forEach(function(indicator) {
      indicator.classList.remove('filled', 'correct', 'incorrect');
    });

    for (let index = 0; index < value.length; index += 1) {
      if (indicators[index]) {
        indicators[index].classList.add('filled');
      }
    }

    if (value.length === passwordLength) {
      validatePassword(value);
    }
  }

  function validatePassword(password) {
    fetch('/view/' + encodeURIComponent(pageId) + '/password', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ password })
    })
      .then(function(response) {
        if (!response.ok) {
          return { valid: false };
        }
        return response.json();
      })
      .then(function(data) {
        const passwordInput = document.querySelector('.password-input');

        if (data.valid) {
          setIndicatorState('correct');
          setTimeout(function() {
            window.location.href = data.redirectUrl || ('/view/' + pageId);
          }, 300);
          return;
        }

        setIndicatorState('incorrect');
        setTimeout(function() {
          if (passwordInput) {
            passwordInput.value = '';
          }
          setIndicatorState(null);
        }, 800);
      })
      .catch(function() {
        setIndicatorState('incorrect');
      });
  }
</script>

<%- include('partials/footer', { page }) %>
