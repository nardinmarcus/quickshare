<%- include('partials/header', { title, page, csrfToken }) %>

<div class="admin-container">
  <header class="admin-header">
    <div>
      <p class="admin-kicker">QuickShare</p>
      <h1 class="admin-title">分享管理</h1>
      <p class="admin-subtitle">共 <%= pagination.total %> 个分享</p>
    </div>
    <%- include('partials/admin-nav', { current: 'pages' }) %>
  </header>

  <div class="admin-header-utility">
    <a class="cyber-btn cyber-btn-secondary" href="/admin/pages/export">
      <i class="fas fa-download" aria-hidden="true"></i>
      <span>导出数据</span>
    </a>
  </div>

  <section class="card admin-card">
    <% if (pagination.total === 0 && !filters.search && !filters.type && !filters.status) { %>
      <div class="admin-empty">
        <h2>还没有分享</h2>
        <p>可以从首页或 Share API 创建第一个分享。</p>
      </div>
    <% } else { %>
      <div class="admin-filter-bar">
        <form class="admin-search-form" method="get" action="/admin/pages">
          <div class="admin-search-box">
            <i class="fas fa-search" aria-hidden="true"></i>
            <input
              type="text"
              name="search"
              value="<%= filters.search %>"
              placeholder="按标题、ID 或描述搜索"
              aria-label="搜索分享"
            >
          </div>
          <input type="hidden" name="type" value="<%= filters.type %>">
          <input type="hidden" name="status" value="<%= filters.status %>">
          <input type="hidden" name="sort" value="<%= filters.sort %>">
          <input type="hidden" name="order" value="<%= filters.order %>">
          <input type="hidden" name="dateFrom" value="<%= filters.dateFrom || '' %>">
          <input type="hidden" name="dateTo" value="<%= filters.dateTo || '' %>">
          <button type="submit" class="cyber-btn cyber-btn-secondary">搜索</button>
          <% if (filters.search) { %>
            <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>&dateFrom=<%= encodeURIComponent(filters.dateFrom || '') %>&dateTo=<%= encodeURIComponent(filters.dateTo || '') %>">清除</a>
          <% } %>
        </form>

        <div class="admin-filter-group">
          <span class="admin-filter-label">日期</span>
          <div class="admin-date-range">
            <input type="date" id="filter-date-from" value="<%= filters.dateFrom || '' %>" aria-label="开始日期">
            <span aria-hidden="true">–</span>
            <input type="date" id="filter-date-to" value="<%= filters.dateTo || '' %>" aria-label="结束日期">
            <button type="button" class="cyber-btn cyber-btn-secondary" id="date-filter-btn">筛选</button>
            <% if (filters.dateFrom || filters.dateTo) { %>
              <% var clearParams = new URLSearchParams(); if (filters.search) clearParams.set('search', filters.search); if (filters.type) clearParams.set('type', filters.type); if (filters.status) clearParams.set('status', filters.status); if (filters.sort) clearParams.set('sort', filters.sort); if (filters.order) clearParams.set('order', filters.order); %>
              <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?<%= clearParams.toString() %>">清除</a>
            <% } %>
          </div>
        </div>

        <div class="admin-filter-group">
          <span class="admin-filter-label">类型</span>
          <div class="admin-filter-buttons">
            <a class="admin-filter-btn <%= !filters.type ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">全部</a>
            <% ['html', 'markdown', 'svg', 'mermaid'].forEach(function(t) { %>
              <a class="admin-filter-btn <%= filters.type === t ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= t %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>"><%= t %></a>
            <% }); %>
          </div>
        </div>

        <div class="admin-filter-group">
          <span class="admin-filter-label">状态</span>
          <div class="admin-filter-buttons">
            <a class="admin-filter-btn <%= !filters.status ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">全部</a>
            <a class="admin-filter-btn <%= filters.status === 'public' ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=public&sort=<%= filters.sort %>&order=<%= filters.order %>">公开</a>
            <a class="admin-filter-btn <%= filters.status === 'protected' ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=protected&sort=<%= filters.sort %>&order=<%= filters.order %>">密码保护</a>
          </div>
        </div>
      </div>

      <% if (pages.length === 0) { %>
        <div class="admin-empty">
          <p>没有符合条件的分享，<a href="/admin/pages">清除全部筛选条件</a>。</p>
        </div>
      <% } else { %>
        <div id="batch-toolbar" class="batch-toolbar" hidden>
          <span id="batch-count">已选择 0 项</span>
          <button type="button" class="cyber-btn" id="batch-delete-btn" disabled>
            <i class="fas fa-trash-alt" aria-hidden="true"></i>
            <span>删除所选</span>
          </button>
          <button type="button" class="cyber-btn cyber-btn-secondary" id="batch-cancel-btn">取消选择</button>
        </div>
        <div class="admin-table-wrap" tabindex="0" aria-label="分享列表，可横向滚动">
          <table class="admin-table">
            <caption class="sr-only">分享列表</caption>
            <thead>
              <tr>
                <th scope="col" class="admin-checkbox-cell">
                  <label class="admin-checkbox-target">
                    <input type="checkbox" id="select-all">
                    <span class="sr-only">选择全部分享</span>
                  </label>
                </th>
                <th scope="col">标题</th>
                <th scope="col" aria-sort="<%= filters.sort === 'code_type' ? (filters.order === 'asc' ? 'ascending' : 'descending') : 'none' %>">
                  <a class="admin-sortable <%= filters.sort === 'code_type' ? filters.order : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=code_type&order=<%= filters.sort === 'code_type' && filters.order === 'desc' ? 'asc' : 'desc' %>">
                    类型 <i class="fas fa-sort<%= filters.sort === 'code_type' ? (filters.order === 'asc' ? '-up' : '-down') : '' %>" aria-hidden="true"></i>
                  </a>
                </th>
                <th scope="col" aria-sort="<%= filters.sort === 'created_at' ? (filters.order === 'asc' ? 'ascending' : 'descending') : 'none' %>">
                  <a class="admin-sortable <%= filters.sort === 'created_at' ? filters.order : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=created_at&order=<%= filters.sort === 'created_at' && filters.order === 'desc' ? 'asc' : 'desc' %>">
                    创建时间 <i class="fas fa-sort<%= filters.sort === 'created_at' ? (filters.order === 'asc' ? '-up' : '-down') : '' %>" aria-hidden="true"></i>
                  </a>
                </th>
                <th scope="col" aria-sort="<%= filters.sort === 'is_protected' ? (filters.order === 'asc' ? 'ascending' : 'descending') : 'none' %>">
                  <a class="admin-sortable <%= filters.sort === 'is_protected' ? filters.order : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=is_protected&order=<%= filters.sort === 'is_protected' && filters.order === 'desc' ? 'asc' : 'desc' %>">
                    状态 <i class="fas fa-sort<%= filters.sort === 'is_protected' ? (filters.order === 'asc' ? '-up' : '-down') : '' %>" aria-hidden="true"></i>
                  </a>
                </th>
                <th scope="col">访问量</th>
                <th scope="col">密码</th>
                <th scope="col">链接</th>
                <th scope="col" class="admin-actions-col">操作</th>
              </tr>
            </thead>
            <tbody>
              <% pages.forEach((sharedPage) => { %>
                <%
                  const now = Date.now();
                  const isExpired = sharedPage.expires_at && Number(sharedPage.expires_at) < now;
                  const isExpiringSoon = sharedPage.expires_at && !isExpired && Number(sharedPage.expires_at) < now + 24 * 60 * 60 * 1000;
                %>
                <tr class="<%= isExpired ? 'admin-expired' : '' %> <%= isExpiringSoon ? 'admin-expiring' : '' %>" data-page-id="<%= sharedPage.id %>">
                  <td class="admin-checkbox-cell">
                    <label class="admin-checkbox-target">
                      <input type="checkbox" class="row-checkbox" data-id="<%= sharedPage.id %>">
                      <span class="sr-only">选择 <%= sharedPage.title || sharedPage.id %></span>
                    </label>
                  </td>
                  <td>
                    <a class="admin-page-title" href="/admin/pages/<%= encodeURIComponent(sharedPage.id) %>">
                      <%= sharedPage.title || sharedPage.id %>
                    </a>
                    <% if (sharedPage.description) { %>
                      <p class="admin-page-description"><%= sharedPage.description %></p>
                    <% } %>
                    <% if (isExpired) { %>
                      <span class="admin-expired-badge">已过期</span>
                    <% } else if (isExpiringSoon) { %>
                      <span class="admin-expiring-badge">即将过期</span>
                    <% } %>
                  </td>
                  <td><span class="admin-pill"><%= sharedPage.code_type || 'html' %></span></td>
                  <td><time datetime="<%= new Date(Number(sharedPage.created_at)).toISOString() %>"><%= new Date(Number(sharedPage.created_at)).toLocaleString('zh-CN', { hour12: false }) %></time></td>
                  <td>
                    <% if (sharedPage.is_protected === 1) { %>
                      <span class="admin-status protected">密码保护</span>
                    <% } else { %>
                      <span class="admin-status public">公开</span>
                    <% } %>
                  </td>
                  <td><%= sharedPage.view_count || 0 %></td>
                  <td>
                    <% if (sharedPage.is_protected === 1 && sharedPage.visiblePassword) { %>
                      <code class="admin-password-value"><%= sharedPage.visiblePassword %></code>
                    <% } else if (sharedPage.is_protected === 1) { %>
                      <span class="admin-muted">不可查看</span>
                    <% } else { %>
                      <span class="admin-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <a class="admin-icon-link" href="<%= publicPageUrl(sharedPage.id) %>" target="_blank" rel="noopener noreferrer" aria-label="打开公开页面">
                      <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                    </a>
                  </td>
                  <td class="admin-actions-col">
                    <form method="post" action="/admin/pages/<%= encodeURIComponent(sharedPage.id) %>/clone" class="admin-inline-form">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="admin-clone-btn" aria-label="克隆分享 <%= sharedPage.title || sharedPage.id %>">
                        <i class="fas fa-copy" aria-hidden="true"></i>
                      </button>
                    </form>
                    <button
                      type="button"
                      class="admin-delete-btn"
                      data-page-id="<%= sharedPage.id %>"
                      data-page-title="<%= sharedPage.title || sharedPage.id %>"
                      aria-label="删除分享 <%= sharedPage.title || sharedPage.id %>"
                    >
                      <i class="fas fa-trash-alt" aria-hidden="true"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <nav class="admin-pagination" aria-label="分享列表分页">
          <% if (pagination.hasPrevious) { %>
            <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?page=<%= pagination.page - 1 %>&search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">上一页</a>
          <% } else { %>
            <span class="cyber-btn cyber-btn-secondary disabled" aria-disabled="true">上一页</span>
          <% } %>
          <span class="admin-page-count">第 <%= pagination.page %> / <%= pagination.totalPages %> 页</span>
          <span class="admin-page-jump">
            <label class="sr-only" for="jump-page-input">跳转到页码</label>
            <input type="number" id="jump-page-input" min="1" max="<%= pagination.totalPages %>" placeholder="#" aria-label="跳转到页码">
            <button type="button" class="cyber-btn cyber-btn-secondary" id="jump-page-btn">前往</button>
          </span>
          <% if (pagination.hasNext) { %>
            <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?page=<%= pagination.page + 1 %>&search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">下一页</a>
          <% } else { %>
            <span class="cyber-btn cyber-btn-secondary disabled" aria-disabled="true">下一页</span>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </section>
</div>

<div id="delete-modal" class="admin-modal" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title" aria-describedby="delete-modal-description" aria-busy="false" hidden>
  <div class="admin-modal-backdrop" aria-hidden="true"></div>
  <div class="admin-modal-content" tabindex="-1">
    <h3 id="delete-modal-title">确认删除</h3>
    <p id="delete-modal-description">确定要删除 <strong id="delete-modal-target"></strong> 吗？</p>
    <p class="admin-modal-warning">此操作无法撤销。</p>
    <p id="delete-modal-status" class="admin-modal-status" role="status" aria-live="polite" aria-atomic="true" tabindex="-1"></p>
    <div class="admin-modal-actions">
      <button type="button" class="cyber-btn cyber-btn-secondary" id="delete-modal-cancel">取消</button>
      <button type="button" class="cyber-btn" id="delete-modal-confirm">删除</button>
    </div>
  </div>
</div>

<script src="/js/admin.js"></script>
<%- include('partials/footer', { page }) %>
