<%- include('partials/header', { title, page }) %>

<div class="admin-container">
  <header class="admin-header">
    <div>
      <p class="admin-kicker">QuickShare</p>
      <h1 class="admin-title">Admin Pages</h1>
      <p class="admin-subtitle"><%= pagination.total %> shared pages</p>
    </div>
    <div class="admin-actions">
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/stats">
        <i class="fas fa-chart-bar" aria-hidden="true"></i>
        <span>Stats</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/apis">
        <i class="fas fa-key" aria-hidden="true"></i>
        <span>API</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/audit">
        <i class="fas fa-history" aria-hidden="true"></i>
        <span>Audit</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/admin/pages/export">
        <i class="fas fa-download" aria-hidden="true"></i>
        <span>Export</span>
      </a>
      <a class="cyber-btn cyber-btn-secondary admin-home-link" href="/">
        <i class="fas fa-plus" aria-hidden="true"></i>
        <span>Create</span>
      </a>
    </div>
  </header>

  <section class="card admin-card">
    <% if (pagination.total === 0 && !filters.search && !filters.type && !filters.status) { %>
      <div class="admin-empty">
        <h2>No shared pages yet</h2>
        <p>Create a page from the homepage or through the Share API.</p>
      </div>
    <% } else { %>
      <div class="admin-filter-bar">
        <form class="admin-search-form" method="get" action="/admin/pages">
          <div class="admin-search-box">
            <i class="fas fa-search" aria-hidden="true"></i>
            <input
              type="text"
              name="search"
              value="<%= filters.search %>"
              placeholder="Search by title, ID, or description..."
              aria-label="Search pages"
            >
          </div>
          <input type="hidden" name="type" value="<%= filters.type %>">
          <input type="hidden" name="status" value="<%= filters.status %>">
          <input type="hidden" name="sort" value="<%= filters.sort %>">
          <input type="hidden" name="order" value="<%= filters.order %>">
          <button type="submit" class="cyber-btn cyber-btn-secondary">Search</button>
          <% if (filters.search) { %>
            <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">Clear</a>
          <% } %>
        </form>

        <div class="admin-filter-group">
          <span class="admin-filter-label">Date:</span>
          <div class="admin-date-range">
            <input type="date" id="filter-date-from" value="<%= filters.dateFrom || '' %>" aria-label="From date">
            <span>–</span>
            <input type="date" id="filter-date-to" value="<%= filters.dateTo || '' %>" aria-label="To date">
            <button type="button" class="cyber-btn cyber-btn-secondary" id="date-filter-btn">Filter</button>
            <% if (filters.dateFrom || filters.dateTo) { %>
              <% var clearParams = new URLSearchParams(); if (filters.search) clearParams.set('search', filters.search); if (filters.type) clearParams.set('type', filters.type); if (filters.status) clearParams.set('status', filters.status); if (filters.sort) clearParams.set('sort', filters.sort); if (filters.order) clearParams.set('order', filters.order); %>
              <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?<%= clearParams.toString() %>">Clear</a>
            <% } %>
          </div>
        </div>

        <div class="admin-filter-group">
          <span class="admin-filter-label">Type:</span>
          <div class="admin-filter-buttons">
            <a class="admin-filter-btn <%= !filters.type ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">All</a>
            <% ['html', 'markdown', 'svg', 'mermaid'].forEach(function(t) { %>
              <a class="admin-filter-btn <%= filters.type === t ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= t %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>"><%= t %></a>
            <% }); %>
          </div>
        </div>

        <div class="admin-filter-group">
          <span class="admin-filter-label">Status:</span>
          <div class="admin-filter-buttons">
            <a class="admin-filter-btn <%= !filters.status ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">All</a>
            <a class="admin-filter-btn <%= filters.status === 'public' ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=public&sort=<%= filters.sort %>&order=<%= filters.order %>">Public</a>
            <a class="admin-filter-btn <%= filters.status === 'protected' ? 'active' : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=protected&sort=<%= filters.sort %>&order=<%= filters.order %>">Protected</a>
          </div>
        </div>
      </div>

      <% if (pages.length === 0) { %>
        <div class="admin-empty" style="padding: 2rem;">
          <p>No pages match your filters. <a href="/admin/pages">Clear all filters</a>.</p>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <div id="batch-toolbar" class="batch-toolbar" hidden>
            <span id="batch-count">0 selected</span>
            <button type="button" class="cyber-btn" id="batch-delete-btn" disabled>
              <i class="fas fa-trash-alt" aria-hidden="true"></i>
              <span>Delete Selected</span>
            </button>
            <button type="button" class="cyber-btn cyber-btn-secondary" id="batch-cancel-btn">Cancel</button>
          </div>
          <table class="admin-table">
            <thead>
              <tr>
                <th><input type="checkbox" id="select-all" aria-label="Select all pages"></th>
                <th>Title</th>
                <th>
                  <a class="admin-sortable <%= filters.sort === 'code_type' ? filters.order : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=code_type&order=<%= filters.sort === 'code_type' && filters.order === 'desc' ? 'asc' : 'desc' %>">
                    Type <i class="fas fa-sort<%= filters.sort === 'code_type' ? (filters.order === 'asc' ? '-up' : '-down') : '' %>" aria-hidden="true"></i>
                  </a>
                </th>
                <th>
                  <a class="admin-sortable <%= filters.sort === 'created_at' ? filters.order : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=created_at&order=<%= filters.sort === 'created_at' && filters.order === 'desc' ? 'asc' : 'desc' %>">
                    Created <i class="fas fa-sort<%= filters.sort === 'created_at' ? (filters.order === 'asc' ? '-up' : '-down') : '' %>" aria-hidden="true"></i>
                  </a>
                </th>
                <th>
                  <a class="admin-sortable <%= filters.sort === 'is_protected' ? filters.order : '' %>" href="/admin/pages?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=is_protected&order=<%= filters.sort === 'is_protected' && filters.order === 'desc' ? 'asc' : 'desc' %>">
                    Status <i class="fas fa-sort<%= filters.sort === 'is_protected' ? (filters.order === 'asc' ? '-up' : '-down') : '' %>" aria-hidden="true"></i>
                  </a>
                </th>
                <th>Views</th>
                <th>Password</th>
                <th>Link</th>
                <th class="admin-actions-col">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% pages.forEach((sharedPage) => { %>
                <%
                  const now = Date.now();
                  const isExpired = sharedPage.expires_at && Number(sharedPage.expires_at) < now;
                  const isExpiringSoon = sharedPage.expires_at && !isExpired && Number(sharedPage.expires_at) < now + 24 * 60 * 60 * 1000;
                %>
                <tr class="<%= isExpired ? 'admin-expired' : '' %> <%= isExpiringSoon ? 'admin-expiring' : '' %>" data-page-id="<%= sharedPage.id %>">
                  <td class="admin-checkbox-cell"><input type="checkbox" class="row-checkbox" data-id="<%= sharedPage.id %>" aria-label="Select <%= sharedPage.title || sharedPage.id %>"></td>
                  <td>
                    <a class="admin-page-title" href="/admin/pages/<%= encodeURIComponent(sharedPage.id) %>">
                      <%= sharedPage.title || sharedPage.id %>
                    </a>
                    <% if (sharedPage.description) { %>
                      <p class="admin-page-description"><%= sharedPage.description %></p>
                    <% } %>
                    <% if (isExpired) { %>
                      <span class="admin-expired-badge">Expired</span>
                    <% } else if (isExpiringSoon) { %>
                      <span class="admin-expiring-badge">Expires soon</span>
                    <% } %>
                  </td>
                  <td><span class="admin-pill"><%= sharedPage.code_type || 'html' %></span></td>
                  <td><time datetime="<%= new Date(Number(sharedPage.created_at)).toISOString() %>"><%= new Date(Number(sharedPage.created_at)).toLocaleString('zh-CN', { hour12: false }) %></time></td>
                  <td>
                    <% if (sharedPage.is_protected === 1) { %>
                      <span class="admin-status protected">Protected</span>
                    <% } else { %>
                      <span class="admin-status public">Public</span>
                    <% } %>
                  </td>
                  <td><%= sharedPage.view_count || 0 %></td>
                  <td>
                    <% if (sharedPage.is_protected === 1 && sharedPage.visiblePassword) { %>
                      <code class="admin-password-value"><%= sharedPage.visiblePassword %></code>
                    <% } else if (sharedPage.is_protected === 1) { %>
                      <span class="admin-muted">Unavailable</span>
                    <% } else { %>
                      <span class="admin-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <a class="admin-icon-link" href="<%= publicPageUrl(sharedPage.id) %>" target="_blank" rel="noopener noreferrer" aria-label="Open public page">
                      <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                    </a>
                  </td>
                  <td>
                    <form method="post" action="/admin/pages/<%= encodeURIComponent(sharedPage.id) %>/clone" style="display:inline" title="Clone page">
                      <button type="submit" class="admin-clone-btn" aria-label="Clone page <%= sharedPage.title || sharedPage.id %>">
                        <i class="fas fa-copy" aria-hidden="true"></i>
                      </button>
                    </form>
                    <button
                      type="button"
                      class="admin-delete-btn"
                      data-page-id="<%= sharedPage.id %>"
                      data-page-title="<%= sharedPage.title || sharedPage.id %>"
                      aria-label="Delete page <%= sharedPage.title || sharedPage.id %>"
                    >
                      <i class="fas fa-trash-alt" aria-hidden="true"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <nav class="admin-pagination" aria-label="Admin pages pagination">
          <% if (pagination.hasPrevious) { %>
            <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?page=<%= pagination.page - 1 %>&search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">Previous</a>
          <% } else { %>
            <span class="cyber-btn cyber-btn-secondary disabled">Previous</span>
          <% } %>
          <span class="admin-page-count">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
          <span class="admin-page-jump">
            <input type="number" id="jump-page-input" min="1" max="<%= pagination.totalPages %>" placeholder="#" aria-label="Jump to page">
            <button type="button" class="cyber-btn cyber-btn-secondary" id="jump-page-btn">Go</button>
          </span>
          <% if (pagination.hasNext) { %>
            <a class="cyber-btn cyber-btn-secondary" href="/admin/pages?page=<%= pagination.page + 1 %>&search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&status=<%= encodeURIComponent(filters.status) %>&sort=<%= filters.sort %>&order=<%= filters.order %>">Next</a>
          <% } else { %>
            <span class="cyber-btn cyber-btn-secondary disabled">Next</span>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </section>
</div>

<div id="delete-modal" class="admin-modal" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title" hidden>
  <div class="admin-modal-backdrop"></div>
  <div class="admin-modal-content">
    <h3 id="delete-modal-title">Confirm Deletion</h3>
    <p>Are you sure you want to delete <strong id="delete-modal-target"></strong>?</p>
    <p class="admin-modal-warning">This action cannot be undone.</p>
    <div class="admin-modal-actions">
      <button type="button" class="cyber-btn cyber-btn-secondary" id="delete-modal-cancel">Cancel</button>
      <button type="button" class="cyber-btn" id="delete-modal-confirm">Delete</button>
    </div>
  </div>
</div>

<script src="/js/admin.js"></script>
<%- include('partials/footer', { page }) %>
