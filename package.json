{
  "name": "quickshare",
  "version": "1.0.0",
  "description": "QuickShare content sharing tool - Express version",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node --max-old-space-size=1024 server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "test": "NODE_ENV=test node --test test/*.test.js",
    "prod": "NODE_ENV=production node --max-old-space-size=1024 server.js",
    "hash-password": "node scripts/hash-password.js",
    "backfill-titles": "node scripts/backfill-page-titles.js"
  },
  "keywords": [
    "html",
    "share",
    "express",
    "ejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "marked": "^15.0.7",
    "morgan": "^1.10.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
