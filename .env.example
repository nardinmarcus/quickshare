# Environment: development, production, test
NODE_ENV=development

# Local server port. Vercel provides PORT automatically.
PORT=5678

# Authentication
AUTH_ENABLED=true
AUTH_PASSWORD=admin123
# Prefer ADMIN_PASSWORD_HASH in production. Generate one with:
# npm run hash-password -- "your-password"
# ADMIN_PASSWORD_HASH=

# Required in production for signed cookies and CSRF tokens.
SESSION_SECRET=change-this-to-a-long-random-secret

# Vercel / Neon Postgres. Production refuses to start without a durable database.
# Use a pooled, non-owner URL at runtime.
# DATABASE_URL=postgresql://user:password@pool-host:5432/database?sslmode=verify-full
# Inject a direct owner URL only into a trusted migration command or CI job.
# Do not persist it in the application runtime environment.
# DATABASE_MIGRATION_URL=postgresql://owner:password@direct-host:5432/database?sslmode=verify-full

# Postgres pool safety budgets; defaults stay below Vercel's 10-second function limit.
POSTGRES_POOL_MAX=3
POSTGRES_CONNECTION_TIMEOUT_MS=2500
POSTGRES_IDLE_TIMEOUT_MS=10000
POSTGRES_STATEMENT_TIMEOUT_MS=4000
POSTGRES_QUERY_TIMEOUT_MS=4500
POSTGRES_IDLE_TRANSACTION_TIMEOUT_MS=5000

# Optional public URLs.
# BASE_URL=https://admin.example.com
# SHARE_BASE_URL=https://share.example.com

# Request-body boundaries. Keep SHARE_BODY_LIMIT aligned with measured production data.
SMALL_BODY_LIMIT=16kb
SHARE_BODY_LIMIT=2mb
